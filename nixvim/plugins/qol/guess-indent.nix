{ ... }:
{
  # guess-indent: при открытии буфера смотрит на уже существующие строки и
  # подставляет shiftwidth/tabstop/expandtab под конкретный файл/проект.
  # Так новый код (например, добавленное поле в класс) сразу пишется с тем же
  # отступом, что и вокруг — 2 пробела в одном проекте, 4 в другом, без правок
  # глобальных опций в options.nix (там остаётся дефолт = 2).
  plugins.guess-indent = {
    enable = true;

    settings = {
      # Сам вешает autocmd на BufReadPost/BufNewFile — определение работает
      # без ручного вызова :GuessIndent.
      auto_cmd = true;

      # .editorconfig имеет приоритет: если в проекте он есть, доверяем ему,
      # а эвристику применяем только там, где явных правил нет.
      override_editorconfig = false;
    };
  };
}
